generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  phone     String?
  brands    Brand[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id        Int      @id @default(autoincrement())
  name      String
  imageUrl  String?
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  branches  Branch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Branch {
  id         Int        @id @default(autoincrement())
  name       String
  imageUrl   String?
  brandId    Int
  brand      Brand      @relation(fields: [brandId], references: [id])
  categories Category[]
  menuItems  MenuItem[]
  kitchens     Kitchen[]
  zones        Zone[]
  optionGroups OptionGroup[]
  orders       Order[]
  qrCodeUrl    String?
  createdAt    DateTime      @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([brandId])
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String
  branchId  Int
  branch    Branch     @relation(fields: [branchId], references: [id])
  items     MenuItem[]
  order     Int        @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([branchId])
}

model MenuItem {
  id           Int           @id @default(autoincrement())
  name         String
  price        Float
  imageUrl     String?
  categoryId   Int
  category     Category      @relation(fields: [categoryId], references: [id])
  branchId     Int
  branch       Branch        @relation(fields: [branchId], references: [id])
  kitchenId    Int?
  kitchen      Kitchen?      @relation(fields: [kitchenId], references: [id])
  optionGroups OptionGroup[]
  orderItems   OrderItem[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([categoryId])
  @@index([branchId])
}

model OptionGroup {
  id        Int        @id @default(autoincrement())
  name      String
  isMultiple Boolean    @default(false)
  branchId  Int
  branch    Branch     @relation(fields: [branchId], references: [id])
  menuItems MenuItem[]
  options   Option[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([branchId])
}

model Option {
  id            Int         @id @default(autoincrement())
  name          String
  price         Float       @default(0)
  optionGroupId Int
  optionGroup   OptionGroup @relation(fields: [optionGroupId], references: [id])
  orderOptions  OrderItemOption[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([optionGroupId])
}

model Kitchen {
  id        Int        @id @default(autoincrement())
  name      String
  branchId  Int
  branch    Branch     @relation(fields: [branchId], references: [id])
  items     MenuItem[]
  orderItems OrderItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([branchId])
}

model Zone {
  id        Int      @id @default(autoincrement())
  name      String
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  tables    Table[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([branchId])
}

model Table {
  id        Int      @id @default(autoincrement())
  name      String
  qrCode    String   @unique @default(uuid())
  zoneId    Int
  zone      Zone     @relation(fields: [zoneId], references: [id])
  orders    Order[]
  status    TableStatus @default(AVAILABLE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
}

enum OrderStatus {
  PENDING
  PREPARING
  SERVED
  CANCELLED
  COMPLETED
  PAID
}

enum PaymentType {
  CASH
  TRANSFER
}

enum OrderSource {
  CUSTOMER
  STAFF
}

model Order {
  id          Int         @id @default(autoincrement())
  orderNumber String      @unique
  status      OrderStatus @default(PENDING)
  source      OrderSource @default(CUSTOMER)
  totalAmount Float
  paymentType PaymentType?
  branchId    Int
  branch      Branch      @relation(fields: [branchId], references: [id])
  tableId     Int?
  table       Table?      @relation(fields: [tableId], references: [id])
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([branchId])
  @@index([tableId])
}

enum OrderItemStatus {
  PENDING
  COOKING
  READY
  SERVED
}

model OrderItem {
  id         Int           @id @default(autoincrement())
  orderId    Int
  order      Order         @relation(fields: [orderId], references: [id])
  menuItemId Int
  menuItem   MenuItem      @relation(fields: [menuItemId], references: [id])
  name       String
  price      Float
  quantity   Int
  kitchenId  Int?
  kitchen    Kitchen?      @relation(fields: [kitchenId], references: [id])
  options    OrderItemOption[]
  status     OrderItemStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  @@index([orderId])
  @@index([kitchenId])
}

model OrderItemOption {
  id          Int       @id @default(autoincrement())
  orderItemId Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  optionId    Int
  option      Option    @relation(fields: [optionId], references: [id])
  name        String
  price       Float

  @@index([orderItemId])
}
